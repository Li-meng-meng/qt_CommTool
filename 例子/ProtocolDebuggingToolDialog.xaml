<Window x:Class="UAV_UP_Sort.windows.ProtocolDebuggingToolDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UAV_UP_Sort.windows"
        xmlns:controls="clr-namespace:UAV_UP_Sort.Controls"
        mc:Ignorable="d"
        Title="协议说明与HEX调试工具" Height="900" Width="1200" 
        WindowStartupLocation="CenterOwner" MinHeight="600" MinWidth="900" Closing="Window_Closing">
    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBlueBrush" Color="#3498DB"/>
        <SolidColorBrush x:Key="BackgroundLightBrush" Color="#F5F6F7"/>
        <SolidColorBrush x:Key="BackgroundWhiteBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderLightBrush" Color="#E1E4E8"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#2C3E50"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#7F8C8D"/>
        <SolidColorBrush x:Key="SuccessGreenBrush" Color="#27AE60"/>
        <SolidColorBrush x:Key="WarningOrangeBrush" Color="#F39C12"/>
        <SolidColorBrush x:Key="SelectedItemBrush" Color="#E8F4FD"/>

        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BackgroundWhiteBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLightBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <Style x:Key="TitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="SubTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,8,0,6"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="HexDisplayStyle" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Background" Value="#1A1A2E"/>
            <Setter Property="Foreground" Value="#00FF00"/>
            <Setter Property="BorderBrush" Value="#0F0F23"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        </Style>

        <Style x:Key="CmdListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLightBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource SelectedItemBrush}"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F0F0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="IdCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16" Background="{StaticResource BackgroundLightBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Border Grid.Row="0" Style="{StaticResource PanelStyle}" Margin="0,0,0,12">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="协议调试工具" FontSize="16" FontWeight="Bold" 
                               Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>


                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBox x:Name="txtHexInput" Width="280" Height="28" TextChanged="txtHexInput_TextChanged"/>
                    <Button x:Name="txtHexInputButton" Grid.Column="1" Height="32" Content="指令校验" Margin="8,0,0,0"  Click="BtnSendHex_Click"/>

                    <Button Content="查看HEX生成代码" 
                            Height="32" Click="ShowHexCodeButton_Click" Margin="8,0,0,0" Visibility="Visible"/>
                    <Button Content="查看解析逻辑"
                            Height="32" Margin="8,0,0,0" Click="ShowParsingLogicButton_Click" Visibility="Collapsed"/>
                </StackPanel>
             
            </Grid>
        </Border>

        <TextBlock x:Name="txtHexInputTip" Text="" Foreground="{StaticResource SuccessGreenBrush}"  VerticalAlignment="Bottom" HorizontalAlignment="Left"  Margin="650,0,4,16"></TextBlock>
        <!-- 主内容区域 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：CMD列表 -->
            <Border Grid.Column="0" Style="{StaticResource PanelStyle}" Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="CMD命令列表" Style="{StaticResource TitleStyle}"/>

                    <!-- 搜索框 -->
                    <TextBox Grid.Row="1" x:Name="CmdSearchBox" Margin="0,0,0,12" 
                             Height="32" Padding="8,0" VerticalContentAlignment="Center"
                             TextChanged="CmdSearchBox_TextChanged"/>

                    <!-- CMD列表 -->
                    <ListBox Grid.Row="2" x:Name="CmdListBox" 
                             SelectionChanged="CmdListBox_SelectionChanged"
                             ItemContainerStyle="{StaticResource CmdListItemStyle}"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Code, StringFormat=0x{0:X2}}" FontFamily="Consolas" 
                                                   FontWeight="Bold" FontSize="14" Foreground="{StaticResource PrimaryBlueBrush}"/>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" 
                                                   FontSize="13" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Grid.Row="1" Text="{Binding Description}" 
                                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                               TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- 中间：ID列表 -->
            <Border Grid.Column="1" Style="{StaticResource PanelStyle}" Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="ID数据标识" Style="{StaticResource TitleStyle}"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="IdPanel" HorizontalAlignment="Left">
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- 右侧：详情和生成区 -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <!-- CMD详情 -->
                <Border Grid.Row="0" Style="{StaticResource PanelStyle}" Margin="0,0,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="协议指令详情" Style="{StaticResource TitleStyle}"/>

                        <Grid Grid.Row="1" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="指令名称:" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Grid.Column="1" x:Name="CmdNameText" FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="1" Text="操作符号格式:" Style="{StaticResource LabelStyle}" Margin="0,8,0,0"/>
                            <TextBox Grid.Row="1" x:Name="OpInput" Grid.Column="1"  Width="80" Margin="0,8,0,0"/>
                            <TextBlock Grid.Row="2" Text="数据1:" Style="{StaticResource LabelStyle}" Margin="0,8,0,0"/>
                            <TextBox Grid.Row="2" x:Name="Data1Text" Grid.Column="1"  Width="80" Margin="0,8,0,0"/>
                            <TextBlock Grid.Row="3" Text="HEX格式:" Style="{StaticResource LabelStyle}" Margin="0,8,0,0"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="HexFormatText"  Width="120"  
                                       FontFamily="Consolas" Foreground="{StaticResource PrimaryBlueBrush}" Margin="0,8,0,0" HorizontalAlignment="Right"/>
                        </Grid>

                        <Grid Grid.Row="1" Grid.Column="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- 1. 标题文本 -->
                            <TextBlock Text="参数说明:" 
               Style="{StaticResource SubTitleStyle}" 
               VerticalAlignment="Top" Margin="0,0,8,0"/>

                            <!-- 2. 帮助按钮 (使用 ToggleButton) -->
                            <Border Background="White" Grid.Column="1" 
BorderBrush="#CCCCCC" 
BorderThickness="1" 
CornerRadius="4" 
Padding="10" 
MaxWidth="300">
                                <StackPanel>
                                    <TextBlock x:Name="InfoTextBlock" FontWeight="Bold" Margin="0,0,0,5"/>

                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <!-- HEX生成区 -->
                <Border Grid.Row="1" Style="{StaticResource PanelStyle}" Margin="0,12,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid>
                            <TextBlock Text="生成指令" Style="{StaticResource TitleStyle}"/>

                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,0" HorizontalAlignment="Right">
                                <Button Content="生成HEX" Width="70" Height="32" Click="GenerateHexButton_Click"/>
                                <Button Content="发送指令" Width="70" Height="32" Margin="6,0,0,0" Click="SendCommandButton_Click"/>

                                <Button Content="一键复制" Width="70" Height="28" Margin="6,0,0,0"
Click="CopyHexButton_Click"/>
                                <TextBlock x:Name="StatusText" VerticalAlignment="Center" 
Margin="6,0,6,0" Foreground="{StaticResource SuccessGreenBrush}" FontSize="11" Visibility="Visible"/>
                            </StackPanel>

                        </Grid>

                        <TextBox Grid.Row="1" x:Name="GeneratedHexText" Style="{StaticResource HexDisplayStyle}" 
                 Height="120" Margin="0,12,0,0"/>


                    </Grid>
                </Border>

                <!-- 硬件数据接收 -->
                <Border Grid.Row="2" Style="{StaticResource PanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid>
                            <TextBlock Text="硬件数据接收" Style="{StaticResource TitleStyle}"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="HZ数:" VerticalAlignment="Center"></TextBlock>
                                <TextBlock x:Name="hztext" VerticalAlignment="Center" Margin="6,0,8,0" Text="0"></TextBlock>
                                <TextBlock Text="显示格式:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <ComboBox x:Name="DisplayFormatCombo" Width="100" Height="24">
                                    <ComboBoxItem Content="HEX" IsSelected="True"/>
                                    <ComboBoxItem Content="原始数据"/>
                                    <ComboBoxItem Content="混合"/>
                                </ComboBox>
                                <Button Content="清空" Width="60" Height="28" Margin="12,0,0,0" Click="ClearDataButton_Click"/>
                            </StackPanel>
                        </Grid>

                        <TextBox Grid.Row="1" x:Name="ReceivedDataText" 
                                 Style="{StaticResource HexDisplayStyle}" Margin="0,12,0,0"/>
                    </Grid>
                </Border>


            </Grid>
        </Grid>
    </Grid>
</Window>
